# Copy this file to .env or .env.local, or set these variables in your
# deployment environment.
# Do not commit real secret values.

DJANGO_SECRET_KEY=replace-this-with-a-long-random-local-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=hiseduplay.run.goorm.io,localhost,127.0.0.1

# Default local database. This creates hiseduplay/db.sqlite3.
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# MySQL deployment example:
# DJANGO_DB_ENGINE=django.db.backends.mysql
# DJANGO_DB_NAME=hiseduplay
# DJANGO_DB_USER=replace-this-with-db-user
# DJANGO_DB_PASSWORD=replace-this-with-db-password
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=3306
