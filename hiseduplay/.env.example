# Copy this file to .env.local or set these variables in your deployment environment.
# Do not commit real secret values.

DJANGO_SECRET_KEY=replace-this-with-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=hiseduplay.run.goorm.io,localhost,127.0.0.1

# Use sqlite locally by omitting the MySQL settings below, or set them for MySQL.
DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=hiseduplay
DJANGO_DB_USER=replace-this-with-db-user
DJANGO_DB_PASSWORD=replace-this-with-db-password
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=3306
